{
    "$schema": "https://captainhookphp.github.io/captainhook/schema.json",
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "/^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\\(.+\\))?!?:\\s.{1,100}$/",
                    "error": "Commit message must follow Conventional Commits format: <type>(<scope>): <description>"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\PHP\\Action\\Linting",
                "options": {
                    "extensions": "php"
                }
            },
            {
                "action": "command -v gitleaks >/dev/null 2>&1 || { echo 'Gitleaks is required for pre-commit secret scanning. Install it with: brew install gitleaks'; exit 1; }; gitleaks protect --staged --verbose --redact --config=.gitleaks.toml",
                "conditions": []
            },
            {
                "action": "composer lint:pint",
                "conditions": []
            },
            {
                "action": "composer lint:phpcs",
                "conditions": []
            },
            {
                "action": "composer lint:phpstan",
                "conditions": []
            },
            {
                "action": "composer lint:phpmd",
                "conditions": []
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "command -v gitleaks >/dev/null 2>&1 && gitleaks detect --verbose --redact --config=.gitleaks.toml || echo 'Note: Gitleaks scan skipped or failed. Install gitleaks for full local secret scanning: brew install gitleaks'",
                "conditions": []
            },
            {
                "action": "composer test",
                "conditions": []
            }
        ]
    },
    "post-merge": {
        "enabled": false,
        "actions": []
    },
    "post-checkout": {
        "enabled": false,
        "actions": []
    },
    "post-rewrite": {
        "enabled": false,
        "actions": []
    },
    "post-change": {
        "enabled": false,
        "actions": []
    },
    "prepare-commit-msg": {
        "enabled": false,
        "actions": []
    }
}
