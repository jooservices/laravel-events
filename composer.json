{
    "name": "jooservices/laravel-events",
    "description": "EventSourcing and EventLog for Laravel with MongoDB storage",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "events",
        "event-sourcing",
        "event-log",
        "audit-log",
        "mongodb",
        "eloquent",
        "persistence"
    ],
    "authors": [
        {
            "name": "JOOservices",
            "email": "admin@jooservices.com"
        }
    ],
    "support": {
        "issues": "https://github.com/jooservices/laravel-events/issues",
        "source": "https://github.com/jooservices/laravel-events"
    },
    "require": {
        "php": "^8.5",
        "laravel/framework": "^12.0",
        "mongodb/laravel-mongodb": "^5.6"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.23",
        "captainhook/plugin-composer": "^5.3",
        "friendsofphp/php-cs-fixer": "^3.65",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0 || ^13.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "JOOservices\\LaravelEvents\\": "src/",
            "JooServices\\LaravelEvents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JOOservices\\LaravelEvents\\Tests\\": "tests/",
            "JooServices\\LaravelEvents\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JOOservices\\LaravelEvents\\EventsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "test:coverage": "phpunit -c phpunit.xml --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "lint:pint": "pint --test",
        "lint:pint:fix": "pint",
        "lint:cs": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --sequential",
        "lint:cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --sequential",
        "lint:phpstan": "phpstan analyse --memory-limit=512M",
        "lint:phpmd": "@php -d error_reporting=24575 vendor/bin/phpmd src,tests text phpmd.xml",
        "lint:phpcs": "phpcs --standard=phpcs.xml",
        "lint": [
            "@lint:pint",
            "@lint:phpcs",
            "@lint:phpstan"
        ],
        "lint:all": [
            "@lint",
            "@lint:phpmd",
            "@lint:cs"
        ],
        "lint:fix": [
            "@lint:pint:fix",
            "@lint:cs:fix"
        ],
        "check": [
            "@lint:all",
            "@test"
        ],
        "ci": [
            "@lint:all",
            "@test:coverage"
        ],
        "post-install-cmd": "captainhook install --force --skip-existing",
        "post-update-cmd": "captainhook install --force --skip-existing",
        "pint": "@lint:pint:fix",
        "pint:fix": "@lint:pint:fix",
        "phpstan": "@lint:phpstan",
        "phpmd": "@lint:phpmd",
        "phpcs": "@lint:phpcs"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "captainhook/plugin-composer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
