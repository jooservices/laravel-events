{
    "name": "jooservices/laravel-events",
    "description": "EventSourcing and EventLog for Laravel with MongoDB storage",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": "^8.5",
        "laravel/framework": "^12.0",
        "mongodb/laravel-mongodb": "^5.6"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "JooServices\\LaravelEvents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JooServices\\LaravelEvents\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JooServices\\LaravelEvents\\EventsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "test:coverage": "phpunit -c phpunit.xml --coverage-text",
        "pint": "pint",
        "pint:fix": "pint",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpmd": "@php -d error_reporting=24575 vendor/bin/phpmd src,tests text phpmd.xml",
        "phpcs": "phpcs --standard=phpcs.xml",
        "lint": [
            "@pint",
            "@phpstan",
            "@phpmd",
            "@phpcs"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
